local _prevPos,_prevTime={},{}
local function getBoneVel(bone)
local now=tick(); local cur=bone.Position
local prev=_prevPos[bone]; local pt=_prevTime[bone]
_prevPos[bone]=cur; _prevTime[bone]=now
if not prev or not pt then return Vector3.new(0,0,0) end
local dt=now-pt
if dt<=0 or dt>0.5 then return Vector3.new(0,0,0) end
return (cur-prev)/dt
end
local function getNearestTarget()
local char=LocalPlayer and LocalPlayer.Character
if not char then return nil end
local vp=Camera.ViewportSize
local cx,cy=vp.X*0.5,vp.Y*0.5
local fovSq=AIM.fov*AIM.fov
local best,bestDSq=nil,huge
local function checkChar(charModel,isPlayer)
if AIM.targetMode==string.char(110, 112, 99) and isPlayer then return end
if AIM.targetMode==string.char(112, 108, 97, 121, 101, 114, 115) and not isPlayer then return end
local bone=charModel:FindFirstChild(AIM.bone) or charModel:FindFirstChild(string.char(72, 117, 109, 97, 110, 111, 105, 100, 82, 111, 111, 116, 80, 97, 114, 116))
if not bone then return end
local hum=charModel:FindFirstChildOfClass(string.char(72, 117, 109, 97, 110, 111, 105, 100))
if hum and hum.Health<=0 then return end
local sc,on=WorldToScreen(bone.Position)
if not on then return end
local dx=sc.X-cx; local dy=sc.Y-cy; local dSq=dx*dx+dy*dy
if dSq<fovSq and dSq<bestDSq then bestDSq=dSq; best=bone end
end
for _,e in ipairs(entObjects) do
if e.char and e.char.Parent then checkChar(e.char,e.isPlayer) end
end
return best
end
local function doAimbot()
if not AIM.enabled then fovCircle.Visible=false; return end
if AIM.showFOV then
local vp=Camera.ViewportSize
fovCircle.Position=Vector2.new(vp.X*0.5,vp.Y*0.5)
fovCircle.Radius=AIM.fov; fovCircle.Visible=true
else fovCircle.Visible=false end
local keyDown=false
if AIM.keyType==string.char(109, 111, 117, 115, 101, 49) then keyDown=ismouse1pressed()
elseif AIM.keyType==string.char(109, 111, 117, 115, 101, 50) then keyDown=ismouse2pressed()
elseif AIM.keyType==string.char(109, 111, 117, 115, 101, 51) then pcall(function() keyDown=iskeypressed(0x04) end)
elseif AIM.keyType==string.char(109, 111, 117, 115, 101, 52) then pcall(function() keyDown=iskeypressed(0x05) end)
elseif AIM.keyType==string.char(109, 111, 117, 115, 101, 53) then pcall(function() keyDown=iskeypressed(0x06) end)
elseif AIM.keyType==string.char(107, 101, 121) and AIM.keyCode then keyDown=iskeypressed(AIM.keyCode) end
if not keyDown then return end
local target=getNearestTarget()
if not target then return end
local vel=getBoneVel(target)
local predPos=target.Position+vel*AIM.predTime
local sc,on=WorldToScreen(predPos)
if not on then return end
local vp=Camera.ViewportSize
local dx=sc.X-(vp.X*0.5); local dy=sc.Y-(vp.Y*0.5)
if abs(dx)<1 and abs(dy)<1 then return end
local smooth=AIM.smooth
local mx=floor(dx*smooth); local my=floor(dy*smooth)
if mx==0 and abs(dx)>=1 then mx=dx>0 and 1 or -1 end
if my==0 and abs(dy)>=1 then my=dy>0 and 1 or -1 end
mousemoverel(mx,my)
end
